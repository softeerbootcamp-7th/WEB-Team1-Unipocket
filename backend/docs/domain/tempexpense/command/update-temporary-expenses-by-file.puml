@startuml
 title tempexpense.command.update-temporary-expenses-by-file
 autonumber
 actor Client
 box "Presentation Layer" #E3F2FD
  participant "TemporaryExpenseCommandController" as Controller
 end box
 box "Facade Layer" #E8F5E9
  participant "TemporaryExpenseCommandFacade" as Facade
 end box
 box "Application Layer" #FFF8E1
  participant "TemporaryExpenseBulkUpdateService" as BulkUpdateService
 end box
 box "Persistence Layer" #F5F5F5
  participant "TemporaryExpenseRepository" as TempExpenseRepo
 end box
 box "Cross Domain Providers" #FCE4EC
  participant "AccountBookValidationProvider (accountbook)" as AccountBookValidator
  participant "AccountBookRateInfoProvider (accountbook)" as RateInfoProvider
 end box

 Client -> Controller : PATCH /account-books/{id}/temporary-expense-metas/{metaId}/files/{fileId}/temporary-expenses
 Controller -> Facade : updateTemporaryExpensesByFile(...)
 Facade -> AccountBookValidator : validateOwnership(accountBookId, userId)
 Facade -> BulkUpdateService : updateByFile(accountBookId, metaId, fileId, request)
 BulkUpdateService -> TempExpenseRepo : findAllById(requestedIds)
 BulkUpdateService -> TempExpenseRepo : findScopedByIds(requestedIds, metaId, fileId)
 BulkUpdateService -> RateInfoProvider : getRateInfo(accountBookId)
 loop request.items
  BulkUpdateService -> BulkUpdateService : 필드 병합 + 상태 재평가
  BulkUpdateService -> TempExpenseRepo : save(updated temporaryExpense)
 end
 Facade --> Controller : TemporaryExpenseMetaBulkUpdateResponse
 Controller --> Client : 200 OK
@enduml
